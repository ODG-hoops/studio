
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Orders: Anyone can create (during checkout), but only admins can read/update
    match /orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // Products: Anyone can read, but only admins can manage
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Rate Limits: System only. 
    // Note: Since we use Client SDK in Server Actions, we allow specific create/update 
    // but in a production environment with Admin SDK, this would be 'if false'
    match /rateLimits/{limitId} {
      allow read, write: if false; 
    }
  }
}
