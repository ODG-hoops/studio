
{
  "entities": {
    "Order": {
      "title": "Order",
      "description": "A customer order containing items and delivery info.",
      "type": "object",
      "properties": {
        "customerEmail": { "type": "string", "format": "email" },
        "items": { "type": "array" },
        "total": { "type": "number" },
        "location": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "paymentReference": { "type": "string" }
      },
      "required": ["customerEmail", "items", "total", "location", "status", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "A goods item available for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number", "description": "Current inventory count." },
        "image": { "type": "string" },
        "imageHint": { "type": "string" },
        "category": { "type": "string" },
        "colors": { "type": "array", "items": { "type": "string" } },
        "sizes": { "type": "array", "items": { "type": "string" } },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "stock", "image", "category", "colors", "sizes"]
    },
    "RateLimit": {
      "title": "Rate Limit",
      "description": "Internal record used for server-side rate limiting.",
      "type": "object",
      "properties": {
        "attempts": { "type": "number" },
        "lastAttempt": { "type": "string", "format": "date-time" },
        "blockedUntil": { "type": "string", "format": "date-time" }
      },
      "required": ["attempts", "lastAttempt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/orders/{orderId}": {
      "schema": "#/backend/entities/Order",
      "description": "Collection of orders placed by customers."
    },
    "/products/{productId}": {
      "schema": "#/backend/entities/Product",
      "description": "Collection of products available in the shop."
    },
    "/rateLimits/{limitId}": {
      "schema": "#/backend/entities/RateLimit",
      "description": "Internal collection for tracking request attempts."
    }
  }
}
